</div>
</div>
</li>
</ul>
</div>


</div>

<div class="link_basic sp mt20"><a href="/keiba/baba/condition/" class="btn-def btn-sm btn-narrow"><i class="fa fa-chevron-circle-right" aria-hidden="true"></i>馬場状態に関する基礎知識</a></div>

</div><!-- /[.line] -->


<div class="line cushion" id="cushion_data">
<div class="block_header opt">
<div class="content">
<div class="main"><h3>芝のクッション値</h3></div>
<div class="opt"><a href="/keiba/baba/cushion/" class="btn-def btn-sm btn-narrow"><i class="fa fa-chevron-circle-right" aria-hidden="true"></i>クッション値の基礎知識</a></div>
</div>
</div>


<div class="grid bottom">
<div class="cell time">
<ul class="data_line_list" data-head-width="180">
<li>
<div class="data_list_unit">
<div class="head"><h4><label for="cushion_list">測定時刻</label></h4></div>
<div class="content">
<div class="dropdown"><select name="cushion_list" id="cushion_list" class="dropdown-select" title="測定時刻の選択" tabindex="0"></select></div>
