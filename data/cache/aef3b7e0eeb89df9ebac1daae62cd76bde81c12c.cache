</div>
</div>
</li>
</ul>
</div>
</div>

<div class="grid graph">
<div class="cell data">
<ul class="data_line_list cushion_data">
<li>
<div class="data_list_unit">
<div class="head"><h4>クッション値</h4></div>
<div class="content" id="cushion_num"><p><strong></strong></p></div>
</div>
</li>
</ul>
</div>
<div class="cell graph">
<div class="cushion_unit">
<div class="graph">
<div class="bar">
<ul>
<li class="break p1">12</li>
<li class="break p2">10</li>
<li class="break p3">8</li>
<li class="break p4">7</li>
</ul>
</div>
<div class="point" title="クッション値"></div>
</div>

<div class="cushion_type">
<div class="type hard">硬め</div>
<div class="type firm">やや硬め</div>
<div class="type standard">標準</div>
<div class="type mild">やや軟らか</div>
<div class="type soft">軟らか</div>
</div>
</div><!-- /[.cushion_unit] -->
</div>
</div>

<div id="cushion_relation">
<table class="basic fixed narrow">
<caption class="simple title-s"><div class="inner"><div class="main">クッション値とクッション性との関係性（参考）</div></div></caption>
<thead>
<tr>
<th scope="col">芝馬場の<span>クッション値</span></th>
<th scope="col">馬場表層の<span>クッション性</span></th>
</tr>
</thead>
<tbody>
<tr><td><strong>12<span>以上</span></strong></td><td>硬め</td></tr>
<tr><td><strong>10<span>から</span>12</strong></td><td>やや硬め</td></tr>
<tr><td><strong>8<span>から</span>10</strong></td><td>標準</td></tr>
<tr><td><strong>7<span>から</span>8</strong></td><td>やや軟らかめ</td></tr>
<tr><td><strong>7<span>以下</span></strong></td><td>軟らかめ</td></tr>
</tbody>
</table>
</div>



<div class="link_basic sp mt20"><a href="/keiba/baba/cushion/" class="btn-def btn-sm btn-narrow"><i class="fa fa-chevron-circle-right" aria-hidden="true"></i>クッション値に関する基礎知識</a></div>
</div><!-- /[.line] -->

<div class="line moist" id="moist_data">
<div class="block_header opt">
<div class="content">
<div class="main"><h3>含水率</h3></div>
<div class="opt"><a href="/keiba/baba/moist/" class="btn-def btn-sm btn-narrow"><i class="fa fa-chevron-circle-right" aria-hidden="true"></i>含水率に関する基礎知識</a></div>
</div>
</div>

<div class="grid">
<div class="cell time">
<ul class="data_line_list">
<li class="time">
<div class="data_list_unit">
<div class="head"><h4><label for="moist_list">測定時刻</label></h4></div>
<div class="content">
<div class="dropdown"><select name="moist_list" id="moist_list" class="dropdown-select" title="測定時刻の選択" tabindex="0"></select></div>
<a href="#" class="btn-def btn-sm btn-narrow blue" id="btn_moist">変更</a>
</div>
</div>
</li>
</ul>
</div>
</div>

<table class="basic fixed narrow mt15">
<caption class="simple title-s">ゴール前と4コーナーの含水率</caption>
<thead>
<tr>
<th scope="col" class="cap"></th>
<th scope="col" class="gm">ゴール前</th>
<th scope="col" class="c4">4コーナー</th>
</tr>
</thead>
<tbody>
<tr id="turf_line">
<th scope="row">芝</th>
<td class="gm">9.7</td>
<td class="c4">9.1</td>
</tr>
<tr id="dirt_line">
<th scope="row">ダート</th>
<td class="gm">1.4</td>
<td class="c4">1.0</td>
</tr>
</tbody>
</table>

<div class="panel mt15" id="moist_graph">
<h4 class="sub_header">含水率表</h4>
<div class="content">

<div class="item_flex_list col2_moist v-bottom center">
