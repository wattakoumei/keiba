---
import Base from '../layouts/Base.astro';
import { loadDates, fmtDate } from '../lib/races.js';
const dates = loadDates();
const base = import.meta.env.BASE_URL;

const SHOBU = new Set(['本命勝負', '鉄板コツコツ', '穴ボックス']);
const PLACE = { '01': '札幌', '02': '函館', '03': '福島', '04': '新潟', '05': '東京',
  '06': '中山', '07': '中京', '08': '京都', '09': '阪神', '10': '小倉' };
function dateSummary(d) {
  const venues = [...new Set([
    ...d.screenings.map((s) => PLACE[s.place] || s.venue),
    ...d.reports.map((r) => r.course?.track),
  ].filter(Boolean))];
  const shobu = d.screenings.reduce(
    (a, s) => a + (s.races?.filter((x) => SHOBU.has(x.quadrant)).length || 0), 0);
  return { venues, shobu, nRace: d.reports.length, hasScreen: d.screenings.length > 0 };
}
---
<Base title="競馬予想レポート">
  <h1>競馬予想レポート</h1>
  <p class="sub">日付 → その日の勝負レース（根拠付き）→ 予想。市場は選別レイヤーだけで使い（団子度）、予想本体は内在情報のみ・% は出さない。</p>
  {dates.length === 0 ? (
    <p class="panel">まだデータがありません（analyze-race で予想、screen-card で勝負レース選別を出すと並びます）。</p>
  ) : (
    <ul class="date-list">
      {dates.map((d) => {
        const s = dateSummary(d);
        return (
          <li>
            <a href={`${base}dates/${d.ymd}/`}>
              <span class="date">{fmtDate(d.ymd)}</span>
              <span class="name">{s.venues.join('・') || '—'}</span>
              <span class="meta">
                {s.hasScreen && (s.shobu > 0
                  ? <span class="qbadge q-honmei">勝負候補 {s.shobu}</span>
                  : <span class="cnt muted">選別済・勝負候補なし</span>)}
                {s.nRace > 0 && <span class="cnt">予想 {s.nRace}R</span>}
                {!s.hasScreen && s.nRace > 0 && <span class="cnt muted">選別未実行</span>}
              </span>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</Base>
